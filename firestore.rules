rules_version = '2';

// ════════════════════════════════════════════════════════════
//  RxTU10 Dashboard — Firestore Security Rules
// ════════════════════════════════════════════════════════════
//
//  วิธี deploy:
//   1. Firebase Console → Firestore Database → แท็บ "Rules"
//   2. วางเนื้อหาไฟล์นี้ทั้งหมด แล้วกด "Publish"
//   (หรือถ้าใช้ Firebase CLI: `firebase deploy --only firestore:rules`)
//
//  สรุปสิทธิ์:
//   - users: อ่านได้ทุกคนที่ login; แก้/สร้างได้เฉพาะ doc ตัวเอง
//            admin แก้ + ลบ doc คนอื่นได้ (สำหรับ "ให้/ลดเหรียญ" และ "ลบ User")
//   - news:  อ่าน + สร้างได้ทุกคนที่ login; ลบได้เฉพาะ admin; แก้ไม่ได้
//
//  ⚠️ ข้อจำกัด: logic เกม (เหรียญ/คะแนน) คำนวณฝั่ง client แล้วเขียนตรงเข้า
//   Firestore — rules กัน "การแก้ข้อมูลคนอื่น" ได้ แต่กัน "การโกงคะแนน
//   ของตัวเอง" ไม่ได้ ถ้าต้องการ leaderboard ที่เชื่อถือได้จริงต้องย้าย
//   logic รางวัลไปไว้ใน Cloud Functions (backend)
// ════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'prawich.aum@dome.tu.ac.th';
    }

    // ── Users — แก้ได้เฉพาะ document ตัวเอง (admin แก้/ลบ ของคนอื่นได้) ──
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── News feed — อ่าน/สร้างได้ทุกคนที่ login, ลบได้เฉพาะ admin ──
    match /news/{newsId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if isAdmin();
    }

  }
}
