rules_version = '2';

// ════════════════════════════════════════════════════════════
//  RxTU10 v2 — Firestore Security Rules
// ════════════════════════════════════════════════════════════
//
//  Deploy:
//   - Firebase Console → Firestore Database → "Rules" → paste → Publish
//   - or CLI: `firebase deploy --only firestore:rules`
//
//  Model (DECIDED 2026-05-30): client-only, trust-based + LIGHT guards.
//   Rules enforce ownership, role-change protection, and sane ranges.
//   They CANNOT validate game logic (a determined cheater with DevTools can
//   still alter their own coins/pets) — accepted for a class app.
//
//  Roles: 'student' | 'academic' | 'admin'
//   - bootstrap super-admin = ADMIN_EMAIL (can never be locked out)
//   - 'admin'    → full control; only an admin may change anyone's `role`
//   - 'academic' → may add/edit questions (question bank)
//   - users may edit their OWN doc but NOT their own `role` (no self-promotion)
// ════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // role of the requesting user (defaults to 'student' if missing)
    function myRole() {
      return request.auth != null
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student')
        : 'student';
    }
    function isAdmin() {
      return request.auth != null
        && (request.auth.token.email == 'prawich.aum@dome.tu.ac.th' || myRole() == 'admin');
    }
    function isAcademic() {
      return isAdmin() || (request.auth != null && myRole() == 'academic');
    }
    function canEditQuestions() {
      return isAcademic() || (request.auth != null && myRole() == 'instructor');
    }

    // ── Users ──
    //  read: any logged-in user (members list)
    //  create: only your own doc
    //  update: admins anything; otherwise only your own doc, with the `role`
    //          field unchanged and coins kept non-negative (light guards)
    //  delete: admin only
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isAdmin()
        || (
          request.auth.uid == userId
          && request.resource.data.get('role', 'student') == resource.data.get('role', 'student')
          && request.resource.data.get('tags', []) == resource.data.get('tags', [])
          && request.resource.data.get('founder', false) == resource.data.get('founder', false)
          // light anti-cheat: coins in sane range; residence level can't jump >1
          && request.resource.data.get('coins', 0) >= 0
          && request.resource.data.get('coins', 0) <= 50000000
          && request.resource.data.get('residence', {}).get('level', 1) >= 1
          && request.resource.data.get('residence', {}).get('level', 1) <= 12
          && request.resource.data.get('residence', {}).get('level', 1)
             <= resource.data.get('residence', {}).get('level', 1) + 1
          // owner ตั้ง guestStatus ได้แค่ 'pending' (สมัคร) — approve/reject = admin เท่านั้น
          && (
            request.resource.data.get('guestStatus', null) == resource.data.get('guestStatus', null)
            || request.resource.data.get('guestStatus', null) == 'pending'
          )
        )
      );
      allow delete: if isAdmin();

      // ── Mailbox (Mailbox track) — จดหมาย/ของรางวัลรายผู้ใช้ ──
      //  read:   เจ้าของเท่านั้น
      //  create: isAcademic (admin+academic = ทีมงานที่เชื่อใจ) สร้างได้ทุกแบบ
      //          owner สร้างได้เฉพาะจดหมายต้อนรับ welcome-v1 แม่แบบเป๊ะ (กันเสกเหรียญใส่ตัวเอง)
      //  update: เจ้าของ แก้ได้เฉพาะ read/claimed (ห้ามแตะ reward)
      //  delete: เจ้าของ หรือ admin
      match /mail/{mailId} {
        allow read:   if request.auth != null && request.auth.uid == userId;
        // create: ทีมงาน (academic) สร้างได้ทุกแบบ · owner สร้างได้เฉพาะจดหมายต้อนรับแม่แบบเป๊ะ
        //   doc id ตายตัว 'welcome-v1' → มีได้ไม่เกิน 1 ฉบับ/คน (ซ้ำ = update ซึ่งจำกัด field)
        allow create: if isAcademic()
          || (
            request.auth != null && request.auth.uid == userId
            && mailId == 'welcome-v1'
            && request.resource.data.get('from', '') == 'welcome'
            && request.resource.data.get('claimed', true) == false
            && request.resource.data.reward.keys().hasOnly(['coins', 'tickets'])
            && request.resource.data.reward.get('coins', 0) == 15000
            && request.resource.data.reward.get('tickets', 0) == 50
          );
        // update: เจ้าของ แก้ได้เฉพาะ read/claimed และ claimed เปลี่ยนได้ทางเดียว false→true (กดรับซ้ำไม่ได้)
        allow update: if request.auth != null && request.auth.uid == userId
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'claimed'])
                      && (resource.data.get('claimed', false) == false
                          || request.resource.data.get('claimed', false) == true);
        allow delete: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }

      // ── Achievements subcollection — ปลดล็อกความสำเร็จรายผู้ใช้ ──
      //  read:   ผู้ล็อกอินใดก็ได้ (โชว์บนโปรไฟล์)
      //  create: เจ้าของเท่านั้น (self-grant ตอนปลดล็อก)
      //  update/delete: ห้ามเสมอ — เป็น record ที่ไม่เปลี่ยนแปลง
      match /achievements/{achId} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if false;
      }
    }

    // ── App config (launch gate) — config/app { maintenance: bool } ──
    //  PUBLIC read: it's just a boolean, and the gate listener must work
    //  before login + survive a desktop popup login without a page reload.
    //  Write: admin only (toggled from the Admin tab).
    match /config/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Topics — รายชื่อหมวด/หัวข้อข้อสอบ (dropdown) ──
    //  read: public ผ่าน match /config/{doc} ด้านบนอยู่แล้ว (นักศึกษาใช้ดู label สถิติในอนาคต)
    //  write: กว้างกว่า config ปกติ — วิชาการ/อาจารย์เพิ่มหัวข้อเองได้ระหว่างตรวจข้อสอบ
    match /config/topics {
      allow write: if canEditQuestions();
    }

    // ── Exam sets — รายชื่อชุดข้อสอบย้อนหลัง (config/examSets.list = [{name, year}]) ──
    //  read: public ผ่าน match /config/{doc} (นักศึกษาโหลด picker "ข้อสอบย้อนหลัง")
    //  write: วิชาการ/อาจารย์เพิ่มชุดเองได้ระหว่างติดป้ายข้อสอบ (เหมือน topics)
    match /config/examSets {
      allow write: if canEditQuestions();
    }

    // ── Cheat logs — anyone may log themselves; only admin reads ──
    match /cheatLogs/{id} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ── Drug-data error reports (Study tab) — any logged-in user may submit;
    //    only admin reads/triages ──
    match /drugReports/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ── Dev feedback / suggestions — any logged-in user may submit;
    //    only admin reads/triages ──
    match /feedback/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ── News feed — admin posts anything; logged-in users may post
    //    achievement-unlock announcements only (field+length guarded) ──
    match /news/{newsId} {
      allow read:   if request.auth != null;
      allow create: if isAdmin()
        || (request.auth != null
            && request.resource.data.type == 'achievement'
            && request.resource.data.msg is string && request.resource.data.msg.size() <= 140
            && request.resource.data.keys().hasOnly(['msg','icon','type','uid','ts']));
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ── Question bank — editable by Academic Team + Instructors (อาจารย์) ──
    match /questions/{id} {
      // field สรุปผลตรวจบน doc (reviewedBy/reviewPass/reviewFail/reviewStatus) —
      // คิว/สถานะอ่านจาก field พวกนี้ตรงๆ เลยต้องกันแก้มั่ว (ปั่น leaderboard/ปั๊ม passed)
      function reviewKeys() { return ['reviewedBy', 'reviewPass', 'reviewFail', 'reviewStatus', 'reviewVerdicts'].toSet(); }
      function reviewUntouched() {
        return !request.resource.data.diff(resource.data).affectedKeys().hasAny(reviewKeys());
      }
      // ชุด key ที่ยอมให้แตะตอน "ส่งผลตรวจ" = review keys + category (ติดแท็กหมวดระหว่างตรวจ)
      function reviewSubmitKeys() {
        return ['reviewedBy', 'reviewPass', 'reviewFail', 'reviewStatus', 'reviewVerdicts', 'category'].toSet();
      }
      // ส่งผลตรวจจริง: แตะเฉพาะ review fields + ไม่เคยตรวจ + ไม่ใช่ข้อตัวเอง (ยกเว้น import)
      // + เสียงรวม +1 พอดี + transaction เดียวกันต้องเขียน reviews/{uid} ของตัวเองด้วย
      function isReviewSubmit(qid) {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(reviewSubmitKeys())
          && !(request.auth.uid in resource.data.get('reviewedBy', []))
          && (request.auth.uid in request.resource.data.get('reviewedBy', []))
          && (resource.data.get('createdBy', '') != request.auth.uid
              || resource.data.get('source', '') == 'import')
          && request.resource.data.get('reviewPass', 0) + request.resource.data.get('reviewFail', 0)
             == resource.data.get('reviewPass', 0) + resource.data.get('reviewFail', 0) + 1
          && existsAfter(/databases/$(database)/documents/questions/$(qid)/reviews/$(request.auth.uid));
      }
      // ล้างผลตรวจกลับค่าเริ่มต้นเป๊ะ (ตอนแก้เนื้อหาข้อ → กลับเข้าคิวตรวจใหม่)
      function isReviewReset() {
        return request.resource.data.get('reviewedBy', ['x']).size() == 0
          && request.resource.data.get('reviewPass', 1) == 0
          && request.resource.data.get('reviewFail', 1) == 0
          && request.resource.data.get('reviewStatus', '') == 'pending';
      }
      allow read:  if request.auth != null && (resource.data.get('isPublished', false) == true || canEditQuestions());
      allow create, delete: if canEditQuestions();
      allow update: if canEditQuestions()
        && (isAdmin() || reviewUntouched() || isReviewSubmit(id) || isReviewReset());

      // ── Comments (SP1) — thread วิชาการ↔อาจารย์ ต่อข้อ (นักศึกษาเข้าไม่ถึง) ──
      match /comments/{commentId} {
        allow read:   if canEditQuestions();
        // create: ต้องเป็นคนเขียนจริง (กันปลอม authorUid เป็นคนอื่นผ่าน DevTools)
        allow create: if canEditQuestions()
          && request.resource.data.get('authorUid', '') == request.auth.uid;
        allow update, delete: if isAdmin()
          || (request.auth != null && request.auth.uid == resource.data.get('authorUid', ''));
      }

      // ── Reviews (Peer-review วิชาการ) — ผลตรวจรายผู้ตรวจต่อข้อ ──
      //  doc id = uid ของผู้ตรวจ → กันตรวจซ้ำ + กันปลอมเป็นคนอื่น
      //  read:   canEditQuestions (วิชาการ+อาจารย์+แอดมิน) — นักศึกษาเข้าไม่ถึง
      //  create: ต้องเป็นเจ้าของจริง (id == uid และ field reviewerUid == uid)
      //  update: เจ้าของแก้ reason/ref ได้ (ห้ามเปลี่ยน verdict/reviewerUid — กัน desync
      //          กับตัวนับบน doc และกันสวมชื่อคนอื่น) · admin เต็มสิทธิ์
      //  delete: admin (แล้วใช้ปุ่ม "ล้างผลตรวจ" ใน Questions ให้ aggregate กลับเข้าคิว)
      match /reviews/{reviewerUid} {
        allow read:   if canEditQuestions();
        allow create: if canEditQuestions()
          && reviewerUid == request.auth.uid
          && request.resource.data.get('reviewerUid', '') == request.auth.uid;
        allow update: if isAdmin()
          || (canEditQuestions()
              && reviewerUid == request.auth.uid
              && request.resource.data.get('reviewerUid', '') == resource.data.get('reviewerUid', '')
              && request.resource.data.get('verdict', '') == resource.data.get('verdict', ''));
        allow delete: if isAdmin();
      }
    }

    // ── Review meta — ตัวนับ leaderboard "ใครตรวจกี่ข้อ" + ชื่อ snapshot ──
    //  collection แยก (ไม่ใช่ config/ ที่ public-read) เพราะนักศึกษาต้องมองไม่เห็น
    match /reviewMeta/{doc} {
      allow read, write: if canEditQuestions();
    }

    // ── Exam sessions (Phase 2) — owner-only, CREATE-ONLY ──
    //  results are an immutable record (read for the history view; never edited)
    match /examSessions/{id} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Usage stats (Phase 3) — ตัวนับประมาณการการใช้ Firestore รายวัน ──
    //  read: admin (โชว์เกจ/banner) · write: ผู้ใช้ที่ล็อกอิน แต่แตะได้แค่
    //  field reads/writes และต้องไม่ลดลง (increment เท่านั้น) กันการรีเซ็ต/ปลอม
    match /stats/{id} {
      allow read:   if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['reads', 'writes'])
        && request.resource.data.reads  is int && request.resource.data.reads  >= 0
        && request.resource.data.writes is int && request.resource.data.writes >= 0;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reads', 'writes'])
        && request.resource.data.reads  is int && request.resource.data.reads  >= resource.data.get('reads', 0)
        && request.resource.data.writes is int && request.resource.data.writes >= resource.data.get('writes', 0);
      allow delete: if isAdmin();
    }

    // ── Question stats (SP2b) — ตัวนับ %ถูกรายข้อ (increment-only) ──
    //  read:   ผู้แก้คลัง (academic+instructor) เพื่อโชว์ badge 🔴 · นักศึกษาเขียนได้อย่างเดียว
    //  write:  ผู้ล็อกอิน แตะได้แค่ field a/c และต้องไม่ลดลง (increment เท่านั้น) เหมือน stats/{date}
    match /questionStats/{qid} {
      allow read:   if canEditQuestions();
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['a', 'c'])
        && request.resource.data.a is int && request.resource.data.a >= 0
        && request.resource.data.c is int && request.resource.data.c >= 0;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['a', 'c'])
        && request.resource.data.a is int && request.resource.data.a >= resource.data.get('a', 0)
        && request.resource.data.c is int && request.resource.data.c >= resource.data.get('c', 0);
      allow delete: if isAdmin();
    }

    // ── Battle stats (Tower) — ตัวนับสถิติการสู้ราย species (increment-only) ──
    //  read:  ผู้แก้คลัง (academic+instructor) เพื่อจูนตัวเลขจากการเล่นจริง
    //  write: ผู้ล็อกอิน แตะได้แค่ field ชุดนี้ และต้องไม่ลดลง (increment เท่านั้น)
    match /battleStats/{petId} {
      function statFields() { return ['battles','wins','kills','deaths','dmgDealt','dmgTaken']; }
      allow read:   if canEditQuestions();
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(statFields())
        && request.resource.data.battles  is int && request.resource.data.battles  >= 0
        && request.resource.data.wins     is int && request.resource.data.wins     >= 0
        && request.resource.data.kills    is int && request.resource.data.kills    >= 0
        && request.resource.data.deaths   is int && request.resource.data.deaths   >= 0
        && request.resource.data.dmgDealt is int && request.resource.data.dmgDealt >= 0
        && request.resource.data.dmgTaken is int && request.resource.data.dmgTaken >= 0;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(statFields())
        && request.resource.data.battles  >= resource.data.get('battles', 0)
        && request.resource.data.wins     >= resource.data.get('wins', 0)
        && request.resource.data.kills    >= resource.data.get('kills', 0)
        && request.resource.data.deaths   >= resource.data.get('deaths', 0)
        && request.resource.data.dmgDealt >= resource.data.get('dmgDealt', 0)
        && request.resource.data.dmgTaken >= resource.data.get('dmgTaken', 0);
      allow delete: if isAdmin();
    }

    // ── Question reports (Phase 5) — นักศึกษาแจ้งข้อสอบผิด ──
    //  read:   academic เท่านั้น (คนน้อย → ไม่กระทบเพดาน reads รายวันของนักศึกษา)
    //  create: ผู้ล็อกอิน สร้าง report ของตัวเอง (reportedBy ต้องเป็น uid ตัวเอง)
    //  update: academic (ปิด/ตัดสิน) หรือ เจ้าของ report (re-report = setDoc merge → update)
    //  delete: academic
    match /questionReports/{id} {
      allow read:   if isAcademic();
      allow create: if request.auth != null
                    && request.resource.data.reportedBy == request.auth.uid;
      allow update: if isAcademic()
                    || (request.auth != null && resource.data.reportedBy == request.auth.uid);
      allow delete: if isAcademic();
    }

    // (SRS cards live in the user doc at `study.cards` — no subcollection)

    // ── Identity claims — กันจองรหัสนักศึกษาซ้ำ (atomic) ──
    //  doc id = รหัสนักศึกษา · create-only: มีแล้วสร้างทับไม่ได้
    //  delete: admin (ตอนแก้การผูกผิด)
    match /claims/{studentId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && !exists(/databases/$(database)/documents/claims/$(studentId));
      allow update: if false;
      allow delete: if isAdmin();
    }

  }
}
